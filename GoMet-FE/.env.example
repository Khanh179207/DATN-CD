# Copy this file to .env and fill in your values

# OpenAI API Key — required for GoMet AI Chef chat and AI Meal Plan features
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx # tạm thời dừng AI bot thiếu credits gpt

# Google OAuth 2.0 Client ID — required for "Continue with Google" login
# Steps to obtain:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create an OAuth 2.0 Client ID (Web application)
#   3. Add http://localhost:5173 and http://localhost:5174 to Authorized JavaScript origins
#   4. Paste the Client ID below (format: xxxx.apps.googleusercontent.com)
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com